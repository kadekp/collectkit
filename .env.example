# ============================================================
# Environment Variables
# Copy this file to `.env` and fill in your own values.
# Never commit `.env` to source control.
# ============================================================

# ---- LLM API (OpenRouter or any OpenAI-compatible endpoint) ----
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=x-ai/grok-4.1-fast
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- PostgreSQL Database ----
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ---- Messaging provider ----
# Pick one: null (no-op, default), mimin, twilio, telegram.
# See docs/PROVIDERS.md for what each one needs.
MESSAGING_PROVIDER=null

# ---- Mimin.io (WhatsApp) — only used when MESSAGING_PROVIDER=mimin ----
MIMIN_API_TOKEN=your-mimin-bearer-token
MIMIN_STORE=your-store
MIMIN_ACCOUNT_ID=your-account-id
MIMIN_INBOX_ID=your-inbox-id
MIMIN_CAMPAIGN_API_KEY=your-campaign-api-key
MIMIN_CAMPAIGN_URL=https://your-campaign-service.example.com
WHATSAPP_SENDER=15555550199
# Set MIMIN_DISABLED=true to no-op send_text (handy in tests)

# ---- Twilio (WhatsApp or SMS) — only used when MESSAGING_PROVIDER=twilio ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM=whatsapp:+14155238886
TWILIO_CHANNEL=whatsapp
# Set TWILIO_DISABLED=true to no-op send_text

# ---- Telegram — only used when MESSAGING_PROVIDER=telegram ----
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_PARSE_MODE=
# Set TELEGRAM_DISABLED=true to no-op send_text

# ---- Receiver shared secret (optional) ----
# When set, the reference receiver requires X-Shared-Secret on every webhook.
WEBHOOK_SHARED_SECRET=

# ---- Payment-link integration ----
# Base URL used to generate per-customer payment links and check status.
# The bot appends /<customer_number> to this base.
PAYMENT_LINK_BASE=https://example.com/payment-url
PAYMENT_PAID_INDICATOR=customer has no bills
PAYMENT_CHECK_TIMEOUT_SECONDS=10
PAYMENT_CHECK_USER_AGENT=collectkit/1.0

# ---- Locale / Timezone / Currency ----
# Any IANA timezone (e.g. UTC, America/New_York, Europe/London)
TIMEZONE=UTC
# Babel locale used for date and currency formatting (e.g. en_US, es_ES, fr_FR)
LOCALE=en_US
# ISO 4217 currency code (e.g. USD, EUR, GBP)
CURRENCY_CODE=USD

# ---- Persona & Prompts ----
# Path to your persona YAML (relative to repo root or absolute).
# Falls back to config/persona.yaml, then config/persona.example.yaml.
PERSONA_CONFIG=config/persona.yaml
# Directory containing system_prompt.md and YAML siblings
# (followups.yaml, guardrails.yaml, strategies.yaml, reminders.yaml).
PROMPT_DIR=prompts/en

# ---- Scheduled-job hours (in the configured local timezone) ----
# PTP expiry check (default 23 = 11 PM)
PTP_CHECK_HOUR=23
# Bulk borrower-data sync hours (comma-separated, default 7,19)
BULK_SYNC_HOURS=7,19
# Morning follow-up hour (default 9 = 9 AM, Mon-Sat)
FOLLOWUP_HOUR=9
# Daily PTP reminder hour (default 9 = 9 AM)
PTP_REMINDER_HOUR=9

# ---- LangSmith Monitoring (optional but recommended) ----
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=my-bot
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ---- New Relic APM (optional) ----
NEW_RELIC_LICENSE_KEY=your-license-key
NEW_RELIC_APP_NAME=my-bot

# ---- Worker Control ----
# Set to "false" to disable the chatbot (container stays alive, no message processing)
WORKER_ENABLED=true

# ---- A/B Test Configuration ----
# Comma-separated borrower labels that should NOT receive bot responses (control group).
# Leave empty to send the bot to everyone.
CONTROL_GROUP_LABELS=
